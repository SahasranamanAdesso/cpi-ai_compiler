# SAP AI Integration Compiler - Environment Configuration

# ============================================================================
# AI Provider Configuration
# ============================================================================

# Choose which AI provider to use:
# - Set USE_ADESSO_AI_HUB=true to use adesso AI Hub
# - Set USE_ADESSO_AI_HUB=false or leave unset to use Claude API directly

USE_ADESSO_AI_HUB=true

# ============================================================================
# adesso AI Hub Configuration (when USE_ADESSO_AI_HUB=true)
# ============================================================================

# Your adesso AI Hub API key
ADESSO_AI_HUB_API_KEY=your_adesso_ai_hub_api_key_here

# adesso AI Hub API endpoint URL
# Example: https://ai-hub.adesso.de/v1/messages
ADESSO_AI_HUB_URL=https://your-ai-hub-url/v1/messages

# Model to use (optional, defaults to claude-3-5-sonnet-20241022)
ADESSO_AI_HUB_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# Claude API Configuration (when USE_ADESSO_AI_HUB=false)
# ============================================================================

# Your Anthropic Claude API key (only needed if not using adesso AI Hub)
# ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================================
# Server Configuration (optional)
# ============================================================================

# Port for demo server (defaults to 3000)
# PORT=3000
